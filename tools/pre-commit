#!/usr/bin/env bash
# Pre-commit hook: mirrors CI checks so failures never reach GitHub.
# Install: ln -sf ../../tools/pre-commit .git/hooks/pre-commit

set -e

export PATH="$HOME/.cargo/bin:/usr/local/bin:/opt/homebrew/bin:$PATH"

echo "pre-commit: formatting..."
cargo fmt --all -- --check || { echo "FAILED: Run 'cargo fmt --all' to fix."; exit 1; }

echo "pre-commit: clippy..."
cargo clippy -p bridge-core --target "$(rustc -vV | grep host | cut -d' ' -f2)" -- -D warnings || { echo "FAILED: clippy."; exit 1; }

echo "pre-commit: tests..."
cargo test -p bridge-core --target "$(rustc -vV | grep host | cut -d' ' -f2)" --quiet || { echo "FAILED: tests."; exit 1; }

echo "pre-commit: firmware check..."
cargo check -p firmware --quiet 2>/dev/null || { echo "FAILED: firmware."; exit 1; }

echo "pre-commit: frontend build..."
(cd frontend && bun run build 2>&1 | tail -1 | grep -q "done") || { echo "FAILED: frontend build."; exit 1; }

echo "pre-commit: all checks passed."
